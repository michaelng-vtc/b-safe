<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Maui_pg.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Maui_pg"
    xmlns:view="clr-namespace:Maui_pg.Views"
    Shell.FlyoutBehavior="Flyout"
    FlyoutWidth="225">

    <FlyoutItem Title="连接设备" FlyoutIcon="{StaticResource IconBluetoothLE}">
        <ShellContent Title="连接设备"
                      ContentTemplate="{DataTemplate view:MainPage}"
                      Route="MainPage" >
        </ShellContent>
    </FlyoutItem>

    <FlyoutItem Title="定位显示" FlyoutIcon="{StaticResource IconMapMark}">
        <ShellContent Title="定位显示"
                      ContentTemplate="{DataTemplate view:DisplayPage}"
                      Route="DisplayPage">
        </ShellContent>
    </FlyoutItem>

    <FlyoutItem Title="帮助信息" FlyoutIcon="{StaticResource IconAbout}">
        <ShellContent Title="帮助"
                      ContentTemplate="{DataTemplate view:AboutPage}"
                      Route="AboutPage">
        </ShellContent>
    </FlyoutItem>
    
</Shell>

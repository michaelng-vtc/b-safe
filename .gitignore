# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ML model artifacts
*.tflite

# Keil MDK build cache (inside hardware source folders)
D-DWM-PG4.9#C配置资料包V6.8/**/Listings/
D-DWM-PG4.9#C配置资料包V6.8/**/Output/
D-DWM-PG测试包V6.8/**/Listings/
D-DWM-PG测试包V6.8/**/Output/

# Visual Studio build cache (inside hardware source folders)
D-DWM-PG4.9#C配置资料包V6.8/**/.vs/
D-DWM-PG4.9#C配置资料包V6.8/**/bin/
D-DWM-PG4.9#C配置资料包V6.8/**/obj/
D-DWM-PG测试包V6.8/**/.vs/
D-DWM-PG测试包V6.8/**/bin/
D-DWM-PG测试包V6.8/**/obj/

# Large binary files in hardware documentation folders (exceed GitHub 100MB limit)
D-DWM-PG4.9#C配置资料包V6.8/**/*.mp4
D-DWM-PG4.9#C配置资料包V6.8/**/*.rar
D-DWM-PG测试包V6.8/**/*.mp4
D-DWM-PG测试包V6.8/**/*.rar
# J-LINK installer (55 MB, exceeds GitHub recommended 50 MB)
D-DWM-PG4.9#C配置资料包V6.8/J-LINK驱动安装包及说明/

